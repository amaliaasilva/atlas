# ──────────────────────────────────────────────────────────
# Atlas Finance — .env.example
# Copie para .env e ajuste os valores
# ──────────────────────────────────────────────────────────

# Banco de dados
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas_finance

# JWT (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=TROQUE_ESTA_CHAVE_EM_PRODUCAO
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# GCP (opcional em dev local)
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# Upload local (fallback quando GCS não configurado)
UPLOAD_DIR=/tmp/atlas_uploads
